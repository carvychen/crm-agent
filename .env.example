# === MCP server (Slice 1) ===================================================
# Selects cloud-specific endpoints, authority, and FIC audience. Only `global`
# is wired in Slice 1; `china` lands in #7.
CLOUD_ENV=global

# The Dataverse environment the MCP server talks to. No cloud-specific suffix
# is hardcoded anywhere in source — whatever host you point to here is used.
DATAVERSE_URL=https://org7339c4fb.crm.dynamics.com

# AAD app registration that OBO tokens are minted for. See
# docs/adr/0001-obo-with-wif.md and docs/deployment/aad-setup.md (Slice 10).
AAD_APP_CLIENT_ID=
AAD_APP_TENANT_ID=

# When multiple Managed Identities are attached, pin the one that federates
# into the AAD app above. Leave empty to let DefaultAzureCredential resolve.
MANAGED_IDENTITY_CLIENT_ID=

# === Reference agent (Slice 2) ==============================================
# true  -> mounts POST /api/chat alongside /mcp/* (default)
# false -> /mcp/* only; use when a customer runs their own agent
ENABLE_REFERENCE_AGENT=true

# Selects which concrete LLMClient implementation to wire in. Slice 2 ships
# `foundry`; `azure-openai-global`, `azure-openai-cn`, `custom` land in Slice 6.
LLM_PROVIDER=foundry

# Foundry-hosted model endpoint + deployment. The FoundryLLMClient speaks the
# OpenAI-compatible chat completions shape against this base URL.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4o-mini

# The reference agent calls the MCP server over HTTP (ADR 0004) even when
# co-located in the same Function App. In Azure this is the app's public URL
# + /mcp; locally with `func start` it is typically http://localhost:7071/mcp.
MCP_SERVER_URL=http://localhost:7071/mcp
